<script>
    document.addEventListener('DOMContentLoaded', function () {
        const seasonSelectors = document.querySelectorAll('.season-selector:not(.season-selector--link)');
        const seasonContents = document.querySelectorAll('.season-content');

        seasonSelectors.forEach(selector => {
            selector.addEventListener('click', function () {
                const targetSeason = this.getAttribute('data-season');

                seasonSelectors.forEach(s => {
                    s.classList.remove('active');
                });

                this.classList.add('active');

                seasonContents.forEach(content => {
                    content.style.display = 'none';
                });

                const targetContents = document.querySelectorAll(`.season-content[data-season="${targetSeason}"]`);

                targetContents.forEach((targetContent) => {
                    targetContent.removeAttribute('style');
                    targetContent.style.display = 'block';
                    targetContent.style.visibility = 'visible';
                    targetContent.style.opacity = '1';
                });
            });
        });
    });
